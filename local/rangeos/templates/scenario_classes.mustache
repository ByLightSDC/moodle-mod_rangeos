{{!
    Scenario classes management page.

    @template   local_rangeos/scenario_classes
    @copyright  2026 Bylight
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div data-baseurl="{{baseurl}}" data-envid="{{envid}}">
    {{#hasenvironments}}
    <div class="form-group row mb-3">
        <label for="rangeos-env-select" class="col-sm-2 col-form-label">
            {{#str}}selectenvironment, local_rangeos{{/str}}
        </label>
        <div class="col-sm-4">
            <select id="rangeos-env-select" class="custom-select">
                {{#environments}}
                <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                {{/environments}}
            </select>
        </div>
    </div>
    {{/hasenvironments}}

    {{^hasenvironments}}
    <div class="alert alert-info">
        {{#str}}noenvironments, local_rangeos{{/str}}
    </div>
    {{/hasenvironments}}

    {{#haserror}}
    <div class="alert alert-danger">{{error}}</div>
    {{/haserror}}

    <div class="mb-3">
        <button class="btn btn-primary" data-action="create-class">
            {{#str}}createclass, local_rangeos{{/str}}
        </button>
    </div>

    {{#hasclasses}}
    <div class="table-responsive">
    <table class="table table-striped table-sm" id="classes-table">
        <thead>
            <tr>
                <th style="width:30%">{{#str}}classid, local_rangeos{{/str}}</th>
                <th style="width:40%">{{#str}}classinstances, local_rangeos{{/str}}</th>
                <th style="width:30%">{{#str}}actions{{/str}}</th>
            </tr>
        </thead>
        <tbody>
            {{#classes}}
            <tr data-classname="{{name}}" data-rangeid="{{rangeid}}">
                <td>
                    <strong>{{name}}</strong>
                </td>
                <td>
                    <span class="text-muted instance-count" data-classname="{{name}}">
                        {{#str}}loading, local_rangeos{{/str}}
                    </span>
                </td>
                <td>
                    <button class="btn btn-sm btn-outline-info"
                            data-action="view-instances"
                            data-classname="{{name}}"
                            data-rangeid="{{rangeid}}">
                        {{#str}}viewinstances, local_rangeos{{/str}}
                    </button>
                    <button class="btn btn-sm btn-outline-success"
                            data-action="add-seats"
                            data-classname="{{name}}">
                        {{#str}}addseats, local_rangeos{{/str}}
                    </button>
                    <button class="btn btn-sm btn-outline-danger"
                            data-action="delete-class"
                            data-classname="{{name}}">
                        {{#str}}deleteclass, local_rangeos{{/str}}
                    </button>
                </td>
            </tr>
            {{/classes}}
        </tbody>
    </table>
    </div>
    {{/hasclasses}}

    {{^hasclasses}}
    <div class="alert alert-info">
        {{#str}}noclasses, local_rangeos{{/str}}
    </div>
    {{/hasclasses}}

    <!-- Expandable instances detail area -->
    <div id="class-instances-detail" class="mt-3" style="display:none;">
        <h5 id="class-instances-title"></h5>
        <div class="table-responsive">
        <table class="table table-sm table-bordered">
            <thead>
                <tr>
                    <th>Seat</th>
                    <th>{{#str}}scenarioname, local_rangeos{{/str}}</th>
                    <th>{{#str}}status, local_rangeos{{/str}}</th>
                    <th>{{#str}}assignedto, local_rangeos{{/str}}</th>
                    <th>{{#str}}instanceid, local_rangeos{{/str}}</th>
                    <th>{{#str}}actions{{/str}}</th>
                </tr>
            </thead>
            <tbody id="class-instances-body">
            </tbody>
        </table>
        </div>
    </div>
</div>
